rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['fullName', 'email', 'createdAt']) 
        && data.keys().size() == 3
        && data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 100
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 100
        && data.createdAt == request.time;
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.keys().hasAll(['orderId', 'fullName', 'email', 'phone', 'address', 'cartDetails', 'totalAmount', 'status', 'createdAt'])
        && data.keys().size() >= 9 && data.keys().size() <= 10
        && data.orderId is string && data.orderId.size() >= 10 && data.orderId.size() <= 50
        && data.fullName is string && data.fullName.size() >= 2
        && data.email is string && data.email.size() >= 5
        && data.phone is string && data.phone.size() >= 8
        && data.address is string && data.address.size() >= 5
        && data.cartDetails is string && data.cartDetails.size() <= 10000
        && data.totalAmount is number && data.totalAmount >= 0
        && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled']
        && data.createdAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'email']);
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.email == request.auth.token.email || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.email == request.auth.token.email || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidOrder(incoming()) && (incoming().userId == request.auth.uid || incoming().email == request.auth.token.email);
    }
  }
}
